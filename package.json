{
    "name": "@diia-inhouse/providers",
    "version": "1.39.22",
    "description": "common providers",
    "author": "Diia",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "tsc",
        "prebuild": "rimraf dist",
        "prepare": "npm run build",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "files": [
        "dist"
    ],
    "keywords": [],
    "dependencies": {
        "@diia-inhouse/diia-logger": "3.20.4",
        "@diia-inhouse/diia-queue": "13.2.9",
        "@diia-inhouse/errors": "1.18.19",
        "@diia-inhouse/types": "12.0.1",
        "@diia-inhouse/utils": "5.3.21",
        "@diia-inhouse/validators": "1.28.29",
        "lodash": "4.18.1",
        "math-expression-evaluator": "2.0.7",
        "type-fest": "4.34.1"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.18",
        "@types/lodash": "4.17.24",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.29.0",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.2",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "repository": "https://github.com/diia-open-source/be-pkg-providers",
    "license": null
}
