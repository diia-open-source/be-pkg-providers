{
    "name": "@diia-inhouse/providers",
    "version": "2.5.5",
    "type": "module",
    "description": "common providers",
    "author": "Diia",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "build": "tsdown",
        "prebuild": "rimraf dist",
        "prepare": "npm run build",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "files": [
        "dist"
    ],
    "keywords": [],
    "dependencies": {
        "@diia-inhouse/diia-logger": "4.4.8",
        "@diia-inhouse/diia-queue": "14.1.2",
        "@diia-inhouse/errors": "2.2.2",
        "@diia-inhouse/types": "14.1.1",
        "@diia-inhouse/utils": "6.0.43",
        "@diia-inhouse/validators": "2.2.33",
        "lodash": "4.18.1",
        "math-expression-evaluator": "2.0.7",
        "type-fest": "5.6.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/oxc-config": "1.11.0",
        "@diia-inhouse/test": "8.2.17",
        "@types/lodash": "4.17.24",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "25.0.3",
        "tsdown": "0.22.0",
        "typescript": "5.9.3",
        "vitest": "4.1.5",
        "vitest-mock-extended": "4.0.0"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "repository": "https://github.com/diia-open-source/be-pkg-providers",
    "license": null
}
